datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  STAFF
  TECHNICIAN
}

enum PartyType {
  INDIVIDUAL
  SHOP
}

model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  password   String
  role       Role        @default(STAFF)
  phone      String?
  isActive   Boolean     @default(true) @map("is_active")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  complaints Complaint[] @relation("AssignedTechnician")

  @@map("users")
}

model AppSettings {
  id                           String   @id @default(uuid())
  shopName                     String   @map("shop_name")
  shopPhone                    String   @map("shop_phone")
  shopAddress                  String   @map("shop_address")
  complaintPrefix              String   @default("CMP") @map("complaint_prefix")
  defaultCurrency              String   @default("INR") @map("default_currency")
  enableWhatsappNotifications  Boolean  @default(false) @map("enable_whatsapp_notifications")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model Party {
  id             String      @id @default(uuid())
  type           PartyType   @default(INDIVIDUAL)
  name           String
  phone          String
  alternatePhone String?     @map("alternate_phone")
  address        String?
  contactPerson  String?     @map("contact_person")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  complaints     Complaint[]

  @@map("parties")
}

enum ComplaintStatus {
  PENDING
  DIAGNOSING
  REPAIRING
  READY
  DELIVERED
  CANCELLED
}

model Complaint {
  id                   String          @id @default(uuid())
  complaintId          String          @unique // e.g. "RC-1001"
  partyId              String?         @map("party_id")
  party                Party?          @relation(fields: [partyId], references: [id], onDelete: SetNull)
  customerName         String          @map("customer_name")
  customerPhone        String          @map("customer_phone")
  ownerName            String?         @map("owner_name")
  ownerPhone           String?         @map("owner_phone")
  deviceBrand          String          @map("device_brand")
  deviceModel          String          @map("device_model")
  deviceColor          String?         @map("device_color")
  imei                 String?
  issueDescription     String          @map("issue_description")
  accessoriesReceived  String?         @map("accessories_received")
  deviceCondition      String?         @map("device_condition")
  status               ComplaintStatus @default(PENDING)
  estimatedCost        Float           @default(0.0) @map("estimated_cost")
  advancePaid          Float           @default(0.0) @map("advance_paid")
  assignedTechnicianId String?         @map("assigned_technician_id")
  assignedTechnician   User?           @relation("AssignedTechnician", fields: [assignedTechnicianId], references: [id], onDelete: SetNull)
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  logs                 ComplaintLog[]

  @@map("complaints")
}

model ComplaintLog {
  id          String          @id @default(uuid())
  complaintId String          @map("complaint_id")
  complaint   Complaint       @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  oldStatus   ComplaintStatus? @map("old_status")
  newStatus   ComplaintStatus @map("new_status")
  updatedBy   String          @map("updated_by") // user ID or name of the staff who updated it
  createdAt   DateTime        @default(now()) @map("created_at")

  @@map("complaint_logs")
}
